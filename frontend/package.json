{
  "name": "crossborder-ai-demo-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "generate:geography": "node scripts/generate-hk-shenzhen-geography.mjs",
    "generate:api": "../backend/.venv/bin/python ../backend/scripts/export_openapi.py && openapi-typescript ../docs/openapi.json -o src/generated/api.d.ts",
    "check:api": "npm run generate:api && git diff --exit-code -- ../docs/openapi.json src/generated/api.d.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "three": "^0.185.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "vitest": "^4.1.9"
  }
}
